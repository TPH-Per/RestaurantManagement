# .gitignore for RestaurantManagement project

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Build and Binaries
bin/
obj/
publish/
dist/
build/
*.exe
*.dll
*.pdb
*.suo
*.user
*.sln.docstates

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# Flutter / Dart
.dart_tool/
.packages
.pub-cache/
.pub/
build/
ios/Flutter/.last_build_id
android/app/src/main/res/drawable-hdpi/
android/app/src/main/res/drawable-mdpi/
android/app/src/main/res/drawable-xhdpi/
android/app/src/main/res/drawable-xxhdpi/
android/app/src/main/res/drawable-xxxhdpi/
*.flutter-plugins
*.flutter-plugins-dependencies
.metadata
.lock-wscript

# Logs
*.log

# Docker
.dockerignore

# OS specific
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
.env.*.local
